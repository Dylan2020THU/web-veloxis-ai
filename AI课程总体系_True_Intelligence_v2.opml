            <outline text="ORM"/>
            <outline text="Process Reward"/>
          </outline>
          <outline text="Rejection Sampling Fine-tuning / RFT"/>
        </outline>

        <outline text="4.10 Capstone：RLHF mini 复现（小模型 + 偏好数据 + PPO / DPO）"/>
      </outline>

      <outline text="Part Ⅴ · 横向能力栈（新增）">
